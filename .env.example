# Optional: Database connection. The MVP runs statelessly so this is only used
# if you add Prisma queries to the API routes. Schema default is PostgreSQL.
# - Vercel: paste a managed Postgres URL (Vercel Postgres / Neon / Supabase).
# - Local SQLite: switch `provider = "postgresql"` to `"sqlite"` in
#   prisma/schema.prisma and set DATABASE_URL="file:./dev.db".
DATABASE_URL=""

# Optional: URL of the deployed Python FastAPI ML microservice.
# If unset, the Next.js side uses its built-in TypeScript fallback engine,
# which mirrors the same scoring philosophy.
# Local dev example: http://localhost:8000
ML_SERVICE_URL=""

# Optional: OpenAI-compatible API key for LLM due-diligence summaries.
# If unset, a deterministic rule-based template is used so the demo still works.
OPENAI_API_KEY=""

# Optional: model name for the OpenAI-compatible API.
OPENAI_MODEL="gpt-4o-mini"

# Optional: override for non-OpenAI providers (Azure OpenAI, Together, Groq, …).
OPENAI_BASE_URL="https://api.openai.com/v1"

# Public application URL (used by the frontend for absolute links).
NEXT_PUBLIC_APP_URL="http://localhost:3000"
