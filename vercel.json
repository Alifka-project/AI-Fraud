{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "regions": ["fra1"],
  "functions": {
    "src/app/api/analyze/route.ts": { "maxDuration": 60 },
    "src/app/api/upload/route.ts": { "maxDuration": 60 },
    "src/app/api/report/route.ts": { "maxDuration": 15 },
    "src/app/api/health/route.ts": { "maxDuration": 10 }
  }
}
